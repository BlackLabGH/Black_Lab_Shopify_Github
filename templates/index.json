        "padding_top": 10,
        "padding_bottom": 10
      }
    },
    "section_image_with_text_8mFLfT": {
      "type": "section-image-with-text",
      "name": "Image with text",
      "settings": {
        "section_height": "six-fifty-height",
        "layout": "overlay",
        "image_location": "right",
        "image_width": "wide",
        "image": "shopify://shop_images/built_2.png",
        "subheading": "What we couldn't find, we built",
        "title": "<p>Built From Experience. Designed for Real Life.</p>",
        "heading_highlight_type": "circle",
        "highlight_color": "#d43747",
        "highlight_text_color": "#000000",
        "heading_size": 110,
        "content": "<p>We’re dog people, product designers, and problem-solvers. After building one of the original ballistic dog bed companies, we set out to improve on everything we learned...tougher materials, cleaner fabrics, a greener footprint, and most of all improved comfort. Black Lab is the gear we always wanted to design without compromise.</p>",
        "text_alignment": "left",
        "button_text": "Our Story",
        "button_link": "https://blacklabbrands.com/blogs/blog/black-lab-brands-a-new-begining",
        "button_color": "btn--black",
