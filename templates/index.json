    },
    "section_image_with_text_ezy6Kb": {
      "type": "section-image-with-text",
      "name": "Image with text",
      "settings": {
        "section_height": "six-fifty-height",
        "layout": "overlay",
        "image_location": "left",
        "image_width": "wide",
        "image": "shopify://shop_images/tough.png",
        "subheading": "What Makes Us Better",
        "title": "<p>Tough isn’t enough. It's just the beginning.</p>",
        "heading_highlight_type": "circle",
        "highlight_color": "#d43747",
        "highlight_text_color": "#000000",
        "heading_size": 110,
        "content": "<p>We combine next-level durability with thoughtful design details: orthopedic, waterproof Fused Core™ mattresses, StayFresh™ odor-fighting fabric, recycled materials, and covers built to handle real messes...all without sacrificing comfort. No gimmicks. Just gear that performs, feels great, and fits your lifestyle.</p>",
        "text_alignment": "left",
        "button_text": "Learn More",
        "button_link": "https://blacklabbrands.com/blogs/blog/the-eco-friendly-journey-of-black-lab-brands-tougher-greener-cleaner",
        "button_color": "btn--black",
        "button_style": "btn--solid",
