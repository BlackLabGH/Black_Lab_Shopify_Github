    "section_image_with_text_z3dMB4": {
      "type": "section-image-with-text",
      "name": "Image with text",
      "settings": {
        "section_height": "six-fifty-height",
        "layout": "overlay",
        "image_location": "right",
        "image_width": "wide",
        "image": "shopify://shop_images/Beast_2_8aa1adaa-f03f-4edf-a0f4-d764fe56fe77_1.webp",
        "subheading": "Be Loyal. More than just a tagline.",
        "title": "<p>Being loyal is how we live, work, and give back.</p>",
        "heading_highlight_type": "circle",
        "highlight_color": "#d43747",
        "highlight_text_color": "#000000",
        "heading_size": 110,
        "content": "<p>At Black Lab, we’re a small business with a big commitment to doing good. Our <strong>Be Loyal™ Program</strong> is our promise to support pets, people, and the planet. From donating dog beds to animal shelters, to supporting foundations we believe in, to reducing our environmental impact with sustainable materials, we believe in showing up where it matters. The Be Loyal™ Program turns our values into action.</p>",
        "text_alignment": "left",
        "button_text": "Read More",
        "button_link": "https://blacklabbrands.com/blogs/blog/the-black-lab-be-loyal-program",
        "button_color": "btn--black",
        "button_style": "btn--solid",
        "button_size": "btn--small",
